# Agent Configuration Example

# Provider: anthropic, ollama, openai, openai-compatible
provider: anthropic
model: claude-sonnet-4-6
# apiKey: sk-ant-xxx  # Optional, uses ANTHROPIC_API_KEY env var

# Execution mode
mode: yolo  # or 'safe'

# Tool settings
tools:
  bash:
    timeout: 30000
  rm:
    confirm: true

# Session management
session:
  autoSave: true
  saveDir: .agent/sessions

# Logging
logging:
  level: info
  file: .agent/logs/agent.log
