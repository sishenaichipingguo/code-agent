{
  "name": "code-agent",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-powered coding assistant with enterprise reliability and developer experience",
  "main": "dist/index.js",
  "bin": {
    "agent": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "dev:node": "tsx src/cli/index.ts",
    "dev:worker": "bun run src/worker/server.ts",
    "memory:view": "bun run scripts/view-memory.ts",
    "memory:test": "bun run scripts/test-cross-session.ts",
    "memory:migrate": "bun run scripts/migrate-to-chroma.ts",
    "memory:test-phase2": "bun run scripts/test-phase2.ts",
    "build": "bun build src/cli/index.ts --outdir=dist --target=bun",
    "build:binary": "bun build src/cli/index.ts --compile --outfile=dist/agent",
    "test": "bun test",
    "test:unit": "bun test --exclude tests/e2e/**",
    "test:e2e": "bun test tests/e2e/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "chromadb": "^3.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "yaml": "^2.6.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  }
}
